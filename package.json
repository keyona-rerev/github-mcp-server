{
  "name": "github-mcp-server",
  "version": "1.0.0",
  "description": "GitHub MCP server for Claude - repos, files, commits, issues, PRs, and code search",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:express --external:zod",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.0"
  }
}
